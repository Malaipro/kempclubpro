# ============================
# Telegram
# ============================
# Получить у @BotFather после создания бота командой /newbot
TELEGRAM_BOT_TOKEN=

# Произвольная случайная строка — задаётся при регистрации webhook:
# openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ============================
# Supabase (ТОЛЬКО на сервере, никогда не во фронтенде)
# ============================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================
# URLs
# ============================
# URL страницы Mini App на сайте kempclubpro
MINI_APP_URL=https://kempclub.pro/telegram

# Origin фронтенда — для CORS заголовков
ALLOWED_ORIGIN=https://kempclub.pro

# ============================
# Server
# ============================
PORT=3000
NODE_ENV=production
