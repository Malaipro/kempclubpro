# Nginx конфиг для kemp-telegram-server
# Скопировать в /etc/nginx/sites-available/tg.kempclub.pro
# и создать симлинк: ln -s /etc/nginx/sites-available/tg.kempclub.pro /etc/nginx/sites-enabled/
#
# SSL-сертификат получить через Certbot:
#   certbot --nginx -d tg.kempclub.pro

# HTTP → HTTPS редирект
server {
    listen 80;
    listen [::]:80;
    server_name tg.kempclub.pro;

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tg.kempclub.pro;

    # --- SSL (пути заменить после certbot) ---
    ssl_certificate     /etc/letsencrypt/live/tg.kempclub.pro/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tg.kempclub.pro/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # --- Стандартные proxy headers ---
    proxy_http_version  1.1;
    proxy_set_header    Host              $host;
    proxy_set_header    X-Real-IP         $remote_addr;
    proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header    X-Forwarded-Proto $scheme;
    proxy_set_header    Connection        "";

    # --- Telegram Bot Webhook ---
    # Telegram шлёт POST сюда. CORS не нужен — это server-to-server.
    location /webhook {
        proxy_pass http://127.0.0.1:3000/webhook;
        proxy_read_timeout 10s;
    }

    # --- Mini App API ---
    # Браузер (Mini App) шлёт POST /api/state.
    # CORS настроен на стороне Express (ALLOWED_ORIGIN).
    location /api/ {
        proxy_pass http://127.0.0.1:3000/api/;
        proxy_read_timeout 15s;
    }

    # --- Healthcheck ---
    location /health {
        proxy_pass http://127.0.0.1:3000/health;
        proxy_read_timeout 5s;
        access_log off;
    }

    # --- Запретить всё остальное ---
    location / {
        return 404;
    }
}
